# Plantilla del .env de PRODUCCIÓN. Copia este archivo como /opt/slotify/.env en el VPS
# y rellena los valores. NO lo subas al repo (los valores reales son secretos).
# Genera los secretos con los comandos de docs/DEPLOY.md.

# Dominio (para Caddy + CORS)
DOMAIN=slotify.jjalarcon.es

# PostgreSQL (la BD vive solo dentro de Docker)
POSTGRES_DB=slotify
POSTGRES_USER=slotify_user
POSTGRES_PASSWORD=CAMBIA_ESTO_password_largo

# Clave de firma JWT (mínimo 32 bytes). Genera: openssl rand -base64 48
JWT_KEY=CAMBIA_ESTO_clave_jwt

# Claves de cifrado del contacto del invitado (AES-256-GCM + blind index).
# Cada una: 32 bytes en base64. Genera: openssl rand -base64 32
CRYPTO_ENCRYPTION_KEY=CAMBIA_ESTO_base64_32_bytes
CRYPTO_BLIND_INDEX_KEY=CAMBIA_ESTO_base64_32_bytes

# (Opcional) etiqueta de imagen a desplegar; por defecto 'latest'.
# IMAGE_TAG=latest

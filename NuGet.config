<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Aísla las fuentes NuGet a solo nuget.org para este repo.
    <clear/> descarta los feeds privados heredados de la config global
    de la máquina (Evolution / NetUtils), que requieren auth y rompen el restore.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
